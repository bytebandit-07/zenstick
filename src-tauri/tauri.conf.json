  {
    "productName": "ZenStick",
    "version": "0.1.0",
    "identifier": "com.batcave.zenstick",
    "build": {
      "beforeDevCommand": "npm run dev",
      "beforeBuildCommand": "npm run build",
      "devUrl": "http://localhost:5173",
      "frontendDist": "../dist"
    },
    "app": {
      "windows": [
        {
          "label": "main",
          "title": "ZenStick Dashboard",
          "width": 1050,
          "height": 650,
          "minWidth": 800,
          "minHeight": 500,
          "resizable": true,
          "decorations": true,
          "transparent": false,
          "skipTaskbar": false,
          "shadow": true
        },
        {
          "label": "widget",
          "title": "ZenStick Widget",
          "width": 350,
          "height": 500,
          "minWidth": 280,
          "minHeight": 200,
          "resizable": true,
          "decorations": false,
          "transparent": true,
          "alwaysOnTop": false,
          "skipTaskbar": true,
          "visible": false, 
          "shadow": true
        }
      ],
      "security": {
         "capabilities": ["desktop-capability"]
      }
    },
    "bundle": {
      "active": true,
      "targets": "all"
    }
  }