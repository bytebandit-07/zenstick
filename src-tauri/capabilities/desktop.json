{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "desktop-capability",
  "description": "ZenStick desktop capability",
  "windows": ["main", "widget"],
  "webviews": ["main", "widget"],
  "local": true,
  "remote": {
    "urls": [
      "http://localhost:5173/*",
      "http://127.0.0.1:5173/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:default",
    "core:window:allow-hide",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    
    "autostart:default"
  ]
}